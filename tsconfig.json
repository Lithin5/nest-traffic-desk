{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "declaration": true,
    "outDir": "dist",
    "sourceMap": true,
    "strict": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "lib": [
      "ES2021",
      "DOM"
    ]
  },
  "include": [
    "src/**/*.ts",
    "ui/**/*.ts",
    "ui/**/*.tsx"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "assets"
  ]
}
